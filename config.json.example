{
    "app_name": "Pradofy Study Tracker",
    "database_path": "study_sessions.db",
    "window_width": 900,
    "window_height": 600,
    "window_x": 100,
    "window_y": 100,
    "theme": "light",
    "colors": {
        "primary": "#2563eb",
        "secondary": "#60a5fa",
        "success": "#10b981",
        "danger": "#ef4444",
        "warning": "#f59e0b",
        "background": "#f5f7fa",
        "text": "#1e293b"
    },
    "features": {
        "enable_notifications": false,
        "enable_dark_mode": false,
        "auto_save_interval": 300,
        "export_auto_timestamp": true
    }
}
